# Copy this file to .env.local and fill in real values for your deployment.
# Vite only exposes variables prefixed with VITE_ to client-side code.

# Public site URL, used for canonical links, sitemap, and structured data.
VITE_SITE_URL=https://photographer-portfolio-5vclv3x60-thanizh.vercel.app

# Contact form provider (see src/services/contactService.js). Leave unset to
# keep using the built-in stub provider, which logs submissions locally and
# never sends real email.
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=
# VITE_RESEND_API_KEY=
